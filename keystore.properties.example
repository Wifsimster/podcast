# Upload key configuration for Play Store release builds.
#
# Copy this file to `keystore.properties` (which is git-ignored) and fill in
# the values for your upload keystore. app/build.gradle.kts reads these to sign
# the release APK/AAB. On CI, supply the same values via the environment
# variables KEYSTORE_FILE / KEYSTORE_PASSWORD / KEY_ALIAS / KEY_PASSWORD
# instead of this file.
#
# Generate an upload keystore once with:
#   keytool -genkeypair -v -keystore upload-keystore.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# Keep upload-keystore.jks and these passwords OUT of version control and
# backed up safely — losing them means you can no longer ship updates
# (unless you enroll in Play App Signing, which is recommended).

storeFile=upload-keystore.jks
storePassword=changeit
keyAlias=upload
keyPassword=changeit
